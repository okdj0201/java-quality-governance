<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                         https://raw.githubusercontent.com/spotbugs/spotbugs/4.8.6/spotbugs/etc/findbugsfilter.xsd">

    <!-- MapStruct 生成コード -->
    <Match>
        <Class name="~.*MapperImpl"/>
    </Match>

    <!-- Spring Boot メインクラス -->
    <Match>
        <Class name="com.proquip.ProQuipApplication"/>
        <Bug pattern="UMAC_UNCALLABLE_METHOD_OF_ANONYMOUS_CLASS"/>
    </Match>

    <!-- JPA エンティティの equals/hashCode に関する誤検知を除外 -->
    <Match>
        <Package name="com.proquip.domain.entity"/>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
    </Match>
    <Match>
        <Package name="~com\.proquip\.domain\.entity\..*"/>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
    </Match>

    <!-- テストコードの未チェック戻り値は許容 -->
    <Match>
        <Source name="~.*Test\.java"/>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>

</FindBugsFilter>
